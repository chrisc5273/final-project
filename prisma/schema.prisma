generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model checklistitems {
  id                   Int                    @id @default(autoincrement())
  propertyid           Int
  taskdescription      String
  isactive             Boolean                @default(true)
  properties           properties             @relation(fields: [propertyid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_checklistitem_property")
  checklistsubmissions checklistsubmissions[]
}

model checklistsubmissions {
  id              Int            @id @default(autoincrement())
  timesheetid     Int
  checklistitemid Int
  photourl        String
  completedat     DateTime       @db.Timestamp(6)
  checklistitems  checklistitems @relation(fields: [checklistitemid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_submission_checklistitem")
  timesheets      timesheets     @relation(fields: [timesheetid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_submission_timesheet")
}

model properties {
  id                         Int              @id @default(autoincrement())
  name                       String           @db.VarChar(255)
  address                    String
  starttime                  String?          @db.VarChar(50)
  checklistitems             checklistitems[]
  timesheets                 timesheets[]
}

model timesheets {
  id                   Int                    @id @default(autoincrement())
  userid               Int
  propertyid           Int
  clockedin            DateTime               @db.Timestamp(6)
  clockedout           DateTime?              @db.Timestamp(6)
  clockinphotourl      String
  checklistsubmissions checklistsubmissions[]
  properties           properties             @relation(fields: [propertyid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_timesheet_property")
  users                users                  @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_timesheet_user")
  violations           violations[]
}

model users {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(255)
  email       String       @unique @db.VarChar(255)
  password    String       @default("password")
  phonenumber String?      @db.VarChar(50)
  role        String       @default("PORTER") @db.VarChar(50)
  schedule    Json?
  timesheets  timesheets[]
}

